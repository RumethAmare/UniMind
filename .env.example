POSTGRES_DB=unimind
POSTGRES_USER=unimind
POSTGRES_PASSWORD=unimind
POSTGRES_PORT=5432

DATABASE_URL=postgresql://unimind:unimind@localhost:5432/unimind

QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=/api/v1
INTERNAL_API_BASE_URL=http://backend:8000/api/v1

# AI provider settings live in backend/.env.
# Use LLM_PROVIDER=gemini and EMBEDDING_PROVIDER=gemini there for Gemini.
JWT_SECRET_KEY=change-me-in-production
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=768
RAG_TOP_K=5
RAG_MIN_SCORE=0.2
RAG_MAX_CONTEXT_CHARS=12000
